{
  "openapi": "3.1.0",
  "info": {
    "title": "Gongsiri Screen MVP API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/api/v1/reports": {
      "post": {
        "summary": "Read report list/detail data or trigger manual checks for the screen MVP",
        "operationId": "postReports",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/ReportListRequest"
                  },
                  {
                    "$ref": "#/components/schemas/ReportDetailRequest"
                  },
                  {
                    "$ref": "#/components/schemas/ManualCheckRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful page-specific report response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ReportListResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ReportDetailResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ManualCheckResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or manual-check batch too large",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RiskLevel": {
        "type": "string",
        "enum": [
          "normal",
          "caution",
          "high"
        ]
      },
      "ChecklistStatus": {
        "type": "string",
        "enum": [
          "pass",
          "fail",
          "unknown"
        ]
      },
      "FallbackReason": {
        "type": "string",
        "enum": [
          "cold_start_no_cached_reports",
          "cold_start_generated_detail",
          "read_only_manual_check"
        ]
      },
      "FallbackInfo": {
        "type": "object",
        "properties": {
          "used": {
            "type": "boolean"
          },
          "reason": {
            "$ref": "#/components/schemas/FallbackReason"
          }
        },
        "required": [
          "used"
        ],
        "additionalProperties": false
      },
      "ChecklistItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ChecklistStatus"
          },
          "score": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "title",
          "status",
          "score",
          "reason",
          "evidence"
        ],
        "additionalProperties": false
      },
      "ReportSummary": {
        "type": "object",
        "properties": {
          "corpCode": {
            "type": "string"
          },
          "corpName": {
            "type": "string"
          },
          "analyzedAt": {
            "type": "string",
            "format": "date-time"
          },
          "riskLevel": {
            "$ref": "#/components/schemas/RiskLevel"
          },
          "riskScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          }
        },
        "required": [
          "corpCode",
          "corpName",
          "analyzedAt",
          "riskLevel",
          "riskScore"
        ],
        "additionalProperties": false
      },
      "ReportDetail": {
        "type": "object",
        "properties": {
          "corpCode": {
            "type": "string"
          },
          "corpName": {
            "type": "string"
          },
          "analyzedAt": {
            "type": "string",
            "format": "date-time"
          },
          "riskLevel": {
            "$ref": "#/components/schemas/RiskLevel"
          },
          "riskScore": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          },
          "checklist": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChecklistItem"
            }
          },
          "shortTermReport": {
            "type": "string"
          },
          "longTermReport": {
            "type": "string"
          },
          "disclaimer": {
            "type": "string"
          },
          "missingEvidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "corpCode",
          "corpName",
          "analyzedAt",
          "riskLevel",
          "riskScore",
          "checklist",
          "shortTermReport",
          "disclaimer",
          "missingEvidence"
        ],
        "additionalProperties": false
      },
      "ReportListRequest": {
        "type": "object",
        "properties": {
          "view": {
            "const": "report-list"
          },
          "corpCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 20
          }
        },
        "required": [
          "view"
        ],
        "additionalProperties": false
      },
      "ReportDetailRequest": {
        "type": "object",
        "properties": {
          "view": {
            "const": "report-detail"
          },
          "corpCode": {
            "type": "string"
          }
        },
        "required": [
          "view",
          "corpCode"
        ],
        "additionalProperties": false
      },
      "ManualCheckRequest": {
        "type": "object",
        "properties": {
          "view": {
            "const": "manual-check"
          },
          "corpCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "maxItems": 20
          }
        },
        "required": [
          "view",
          "corpCodes"
        ],
        "additionalProperties": false
      },
      "ReportListResponse": {
        "type": "object",
        "properties": {
          "view": {
            "const": "report-list"
          },
          "reports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportSummary"
            }
          },
          "fallback": {
            "$ref": "#/components/schemas/FallbackInfo"
          }
        },
        "required": [
          "view",
          "reports",
          "fallback"
        ],
        "additionalProperties": false
      },
      "ReportDetailResponse": {
        "type": "object",
        "properties": {
          "view": {
            "const": "report-detail"
          },
          "report": {
            "$ref": "#/components/schemas/ReportDetail"
          },
          "fallback": {
            "$ref": "#/components/schemas/FallbackInfo"
          }
        },
        "required": [
          "view",
          "report",
          "fallback"
        ],
        "additionalProperties": false
      },
      "ManualCheckResponse": {
        "type": "object",
        "properties": {
          "view": {
            "const": "manual-check"
          },
          "acceptedCorpCodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "maxBatchSize": {
            "type": "integer",
            "const": 20
          },
          "fallback": {
            "$ref": "#/components/schemas/FallbackInfo"
          }
        },
        "required": [
          "view",
          "acceptedCorpCodes",
          "maxBatchSize",
          "fallback"
        ],
        "additionalProperties": false
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "invalid_request",
                  "batch_limit_exceeded"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "error"
        ],
        "additionalProperties": false
      }
    }
  }
}
